{
  "title": "05 — Integration: Qdrant & llama.cpp",
  "uid": "day23-05-integration",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": {"from": "now-1h", "to": "now"},
  "templating": {"list": [
    {"name": "job", "type": "query", "datasource": {"type": "prometheus", "uid": "prometheus"},
     "query": "label_values(up, job)", "refresh": 2, "includeAll": true, "multi": true,
     "current": {"value": ["$__all"], "text": "All"}}
  ]},
  "panels": [
    {
      "type": "row",
      "title": "─── Day 19 — Qdrant Vector Store ───",
      "id": 10,
      "gridPos": {"x": 0, "y": 0, "w": 24, "h": 1},
      "collapsed": false
    },
    {
      "type": "stat", "title": "Collections",
      "id": 11, "gridPos": {"x": 0, "y": 1, "w": 6, "h": 5},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "sum(collections_total{job=\"day19-qdrant\"})", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "short", "thresholds": {"mode": "absolute", "steps": [
        {"color": "green", "value": null},
        {"color": "yellow", "value": 1},
        {"color": "red", "value": 10}
      ]}}}
    },
    {
      "type": "stat", "title": "Total Vectors",
      "id": 12, "gridPos": {"x": 6, "y": 1, "w": 6, "h": 5},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "sum(collections_vector_total{job=\"day19-qdrant\"})", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "short"}}
    },
    {
      "type": "stat", "title": "Memory Resident",
      "id": 13, "gridPos": {"x": 12, "y": 1, "w": 6, "h": 5},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "memory_resident_bytes{job=\"day19-qdrant\"}", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "bytes"}}
    },
    {
      "type": "stat", "title": "Memory Allocated",
      "id": 14, "gridPos": {"x": 18, "y": 1, "w": 6, "h": 5},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "memory_allocated_bytes{job=\"day19-qdrant\"}", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "bytes"}}
    },
    {
      "type": "timeseries", "title": "Memory Breakdown (bytes)",
      "id": 15, "gridPos": {"x": 0, "y": 6, "w": 12, "h": 7},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "memory_resident_bytes{job=\"day19-qdrant\"}", "legendFormat": "resident", "refId": "A"},
        {"expr": "memory_allocated_bytes{job=\"day19-qdrant\"}", "legendFormat": "allocated", "refId": "B"},
        {"expr": "memory_active_bytes{job=\"day19-qdrant\"}", "legendFormat": "active", "refId": "C"}
      ],
      "fieldConfig": {"defaults": {"unit": "bytes"}}
    },
    {
      "type": "gauge", "title": "Uptime Health",
      "id": 16, "gridPos": {"x": 12, "y": 6, "w": 4, "h": 7},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "up{job=\"day19-qdrant\"}", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "short", "min": 0, "max": 1,
        "thresholds": {"mode": "absolute", "steps": [
          {"color": "red", "value": null},
          {"color": "green", "value": 1}
        ]}}}
    },
    {
      "type": "stat", "title": "Version",
      "id": 17, "gridPos": {"x": 16, "y": 6, "w": 8, "h": 7},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "app_info{job=\"day19-qdrant\"}", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "short", "displayName": "{{name}} v{{version}}"}}
    },

    {
      "type": "row",
      "title": "─── Day 20 — llama.cpp Model Server ───",
      "id": 20,
      "gridPos": {"x": 0, "y": 13, "w": 24, "h": 1},
      "collapsed": false
    },
    {
      "type": "gauge", "title": "GPU Utilization (%)",
      "id": 21, "gridPos": {"x": 0, "y": 14, "w": 6, "h": 7},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "gpu_utilization_percent{job=\"day20-llamacpp\"}", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "percent", "min": 0, "max": 100,
        "thresholds": {"mode": "absolute", "steps": [
          {"color": "green", "value": null},
          {"color": "yellow", "value": 50},
          {"color": "red", "value": 90}
        ]}}}
    },
    {
      "type": "stat", "title": "Busy Slots",
      "id": 22, "gridPos": {"x": 6, "y": 14, "w": 6, "h": 7},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "llamacpp:n_busy_slots_per_decode{job=\"day20-llamacpp\"}", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "short", "min": 0,
        "thresholds": {"mode": "absolute", "steps": [
          {"color": "green", "value": null},
          {"color": "yellow", "value": 2},
          {"color": "red", "value": 4}
        ]}}}
    },
    {
      "type": "stat", "title": "Requests In-Flight",
      "id": 23, "gridPos": {"x": 12, "y": 14, "w": 6, "h": 7},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "llamacpp:requests_processing{job=\"day20-llamacpp\"}", "legendFormat": "processing", "refId": "A"},
        {"expr": "llamacpp:requests_deferred{job=\"day20-llamacpp\"}", "legendFormat": "deferred", "refId": "B"}
      ],
      "fieldConfig": {"defaults": {"unit": "short", "min": 0,
        "thresholds": {"mode": "absolute", "steps": [
          {"color": "green", "value": null},
          {"color": "yellow", "value": 2},
          {"color": "red", "value": 4}
        ]}}}
    },
    {
      "type": "stat", "title": "Max Tokens / Slot",
      "id": 24, "gridPos": {"x": 18, "y": 14, "w": 6, "h": 7},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "llamacpp:n_tokens_max{job=\"day20-llamacpp\"}", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "short"}}
    },

    {
      "type": "timeseries", "title": "Token Throughput (tokens/sec)",
      "id": 25, "gridPos": {"x": 0, "y": 21, "w": 12, "h": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "rate(llamacpp:tokens_predicted_total{job=\"day20-llamacpp\"}[30s])", "legendFormat": "predicted tok/s", "refId": "A"},
        {"expr": "rate(llamacpp:prompt_tokens_total{job=\"day20-llamacpp\"}[30s])", "legendFormat": "prompt tok/s", "refId": "B"}
      ],
      "fieldConfig": {"defaults": {"unit": "ops"}}
    },
    {
      "type": "timeseries", "title": "Decode Count Rate (decodes/sec)",
      "id": 26, "gridPos": {"x": 12, "y": 21, "w": 12, "h": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "rate(llamacpp:n_decode_total{job=\"day20-llamacpp\"}[30s])", "legendFormat": "decodes/s", "refId": "A"}
      ],
      "fieldConfig": {"defaults": {"unit": "ops"}}
    },

    {
      "type": "timeseries", "title": "Latency — Prompt Processing (sec)",
      "id": 27, "gridPos": {"x": 0, "y": 29, "w": 12, "h": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "rate(llamacpp:prompt_seconds_total{job=\"day20-llamacpp\"}[30s])", "legendFormat": "prompt sec/s", "refId": "A"}
      ],
      "fieldConfig": {"defaults": {"unit": "s"}}
    },
    {
      "type": "timeseries", "title": "Latency — Token Prediction (sec)",
      "id": 28, "gridPos": {"x": 12, "y": 29, "w": 12, "h": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "rate(llamacpp:tokens_predicted_seconds_total{job=\"day20-llamacpp\"}[30s])", "legendFormat": "pred sec/s", "refId": "A"}
      ],
      "fieldConfig": {"defaults": {"unit": "s"}}
    },

    {
      "type": "row",
      "title": "─── Day 23 — Inference API (FastAPI) ───",
      "id": 30,
      "gridPos": {"x": 0, "y": 37, "w": 24, "h": 1},
      "collapsed": false
    },
    {
      "type": "stat", "title": "Requests OK (5m)",
      "id": 31, "gridPos": {"x": 0, "y": 38, "w": 6, "h": 6},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "sum(rate(inference_requests_total{status=\"ok\"}[5m]))", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "reqps"}}
    },
    {
      "type": "stat", "title": "Requests Error (5m)",
      "id": 32, "gridPos": {"x": 6, "y": 38, "w": 6, "h": 6},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "sum(rate(inference_requests_total{status=\"error\"}[5m]))", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "reqps",
        "thresholds": {"mode": "absolute", "steps": [
          {"color": "green", "value": null},
          {"color": "red", "value": 0.01}
        ]}}}
    },
    {
      "type": "stat", "title": "Error Rate (%)",
      "id": 33, "gridPos": {"x": 12, "y": 38, "w": 6, "h": 6},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "inference:fail_ratio:rate5m", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "percentunit", "min": 0, "max": 1,
        "thresholds": {"mode": "absolute", "steps": [
          {"color": "green", "value": null},
          {"color": "yellow", "value": 0.01},
          {"color": "red", "value": 0.05}
        ]}}}
    },
    {
      "type": "stat", "title": "Active Requests",
      "id": 34, "gridPos": {"x": 18, "y": 38, "w": 6, "h": 6},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "inference_active_gauge", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "short"}}
    },
    {
      "type": "timeseries", "title": "Latency P50 / P95 / P99 (sec)",
      "id": 35, "gridPos": {"x": 0, "y": 44, "w": 12, "h": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "histogram_quantile(0.50, sum by (le) (rate(inference_latency_seconds_bucket[5m])))", "legendFormat": "P50", "refId": "A"},
        {"expr": "histogram_quantile(0.95, sum by (le) (rate(inference_latency_seconds_bucket[5m])))", "legendFormat": "P95", "refId": "B"},
        {"expr": "histogram_quantile(0.99, sum by (le) (rate(inference_latency_seconds_bucket[5m])))", "legendFormat": "P99", "refId": "C"}
      ],
      "fieldConfig": {"defaults": {"unit": "s"}}
    },
    {
      "type": "timeseries", "title": "Token Throughput (in/out tok/s)",
      "id": 36, "gridPos": {"x": 12, "y": 44, "w": 12, "h": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{
        "expr": "sum by (direction) (rate(inference_tokens_total[1m]))",
        "legendFormat": "{{direction}}", "refId": "A"
      }],
      "fieldConfig": {"defaults": {"unit": "ops"}}
    }
  ]
}
